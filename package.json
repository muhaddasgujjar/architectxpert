{
  "name": "architectxpert-root",
  "private": true,
  "workspaces": [
    "frontend",
    "frontend/shared",
    "cost-analyzer",
    "floorplan-advisor",
    "floorplan-generation",
    "report-analysis"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace=rest-express run dev",
    "dev:floorplan-generation": "npm --workspace=floorplan-generation run start",
    "dev:cost-analyzer": "npm --workspace=cost-analyzer run start",
    "dev:report-analysis": "npm --workspace=report-analysis run start",
    "dev:floorplan-advisor": "npm --workspace=floorplan-advisor run start",
    "dev:all": "npx concurrently \"npm run dev:frontend\" \"npm run dev:floorplan-generation\" \"npm run dev:cost-analyzer\" \"npm run dev:report-analysis\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "tsx": "^4.21.0"
  }
}
